{
  "name": "flowtest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b && tsc --noEmit -p tsconfig.tools.json && pnpm bundle:page-agent",
    "bundle:page-agent": "tsx scripts/build-page-agent-bundle.ts",
    "demo:server": "tsx examples/local-app/server.ts",
    "flowtest": "tsx apps/cli/src/index.ts",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
